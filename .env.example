# ═══════════════════════════════════════════════════════════════════
# Yobbul Client — Variables d'environnement Expo
# Copier en .env — accessibles via expo-constants / process.env
# ═══════════════════════════════════════════════════════════════════

# Point d'entrée unique — API Gateway (tous les microservices REST)
EXPO_PUBLIC_API_URL=http://localhost:3000

# WebSocket tracking — connexion directe (pas encore proxyfié par le gateway)
EXPO_PUBLIC_TRACKING_WS_URL=ws://localhost:3003/tracking

# Google Maps (React Native Maps)
EXPO_PUBLIC_GOOGLE_MAPS_KEY_IOS=your-ios-google-maps-key
EXPO_PUBLIC_GOOGLE_MAPS_KEY_ANDROID=your-android-google-maps-key

# Google Places API (autocomplete adresse dans PlacesSearchInput)
EXPO_PUBLIC_GOOGLE_PLACES_KEY=your-google-places-api-key

# Firebase (push notifications)
EXPO_PUBLIC_FIREBASE_PROJECT_ID=yobbul-prod

# Environment
EXPO_PUBLIC_ENV=development
